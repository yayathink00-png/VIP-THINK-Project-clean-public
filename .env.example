# Copy this file to .env and fill local values.
# Do not commit real DingTalk client secrets, tokens, webhooks, OAuth files, or API keys.

# DingTalk reconciliation bot
DINGTALK_ROBOT_NAME=内容机器人
DINGTALK_ROBOT_CODE=
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_GROUP_ID=
DINGTALK_POLL_START_TIME=
DINGTALK_SHEET_NODE_ID=
DINGTALK_SHEET_ID=
DINGTALK_SHEET_URL=
DINGTALK_REPLY_SENDER=bot
DINGTALK_OUTPUT_DIR=
DWS_PATH=
HOME=

# Cloudinary publishing tools
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=social-auto-publish

# YouTube OAuth files. Keep the actual files local and do not commit them.
YOUTUBE_CLIENT_SECRET_JSON=
YOUTUBE_REFRESH_TOKEN_FILE=

# Meta / Facebook new creative broadcast
FB_ACCESS_TOKEN=
FB_ALL_AD_ACCOUNTS=
FB_AD_ACCOUNT_ID=
FB_API_VERSION=v21.0
FB_BROADCAST_WEBHOOK_URL=
FB_BROADCAST_ROBOT_TYPE=dingtalk
FB_BROADCAST_DINGTALK_SECRET=
FB_BROADCAST_ACCOUNT_ALIASES=7,8,9,27,18,23
FB_IMAGE_LIBRARY_ROOT=/Volumes/海外投放素材库/图片素材/思维
FB_IMAGE_LIBRARY_START_MONTH=2026-07
FB_BROADCAST_FORCE_DRY_RUN=
FB_BROADCAST_COMMAND_TIMEOUT_SECONDS=1800
