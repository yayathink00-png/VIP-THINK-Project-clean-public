# Copy this file to .env and fill local values.
# Do not commit real DingTalk client secrets, tokens, webhooks, OAuth files, or API keys.

# DingTalk reconciliation bot
DINGTALK_ROBOT_NAME=内容机器人
DINGTALK_ROBOT_CODE=
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_GROUP_ID=
DINGTALK_POLL_START_TIME=
DINGTALK_SHEET_NODE_ID=
DINGTALK_SHEET_ID=
DINGTALK_SHEET_URL=
DINGTALK_REPLY_SENDER=bot
DINGTALK_OUTPUT_DIR=
DWS_PATH=
HOME=

# Cloudinary publishing tools
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=social-auto-publish

# YouTube OAuth files. Keep the actual files local and do not commit them.
YOUTUBE_CLIENT_SECRET_JSON=
YOUTUBE_REFRESH_TOKEN_FILE=
