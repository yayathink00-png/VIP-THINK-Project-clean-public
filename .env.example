# Copy this file to .env and fill values from Cloudinary Console > Settings > API Keys.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional. Uploaded files will be grouped in this Cloudinary folder.
CLOUDINARY_FOLDER=social-auto-publish

# YouTube OAuth files. Keep the actual files local and do not commit them.
YOUTUBE_CLIENT_SECRET_JSON=
YOUTUBE_REFRESH_TOKEN_FILE=
